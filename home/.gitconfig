[alias]
	ss = status --short --branch
	st = status
	br = branch --verbose --verbose
	ci = commit
	co = checkout
	df = diff
	dc = diff --cached
	ll = log --decorate --oneline --graph
	la = log --decorate --oneline --graph --all
	logref = log --decorate --oneline --graph --all --no-merges --simplify-by-decoration
	additions = log --diff-filter=A --no-merges --no-renames --summary
	deletions = log --diff-filter=D --no-merges --no-renames --summary
	purge = clean -d --force
	distclean = clean -d --force --force -x
	tip = !git --no-pager log -1 --first-parent --diff-merges=on --stat --format='format:\
%C(reset)Commit: %C(bold cyan)%h%C(bold magenta)%d%n\
%C(reset)Author: %an <%ae>%n\
%C(reset)AuDate: %ad%n\
%C(reset)CiDate: %cd%n\
%C(reset)%C(bold)%+s%n\
%C(reset)%+b'
	echo = !git --no-pager log -1 --first-parent --diff-merges=on --patch --format='format:\
commit %H%n\
Author: %an <%ae>%n\
Date:   %ad%n\
%+s%n%+b'
[color]
	ui = auto
[color "branch"]
	current = green reverse
	upstream = brightblue
[commit]
	gpgSign = false
	verbose = true
[core]
	excludesFile = ~/.wildignore
	whitespace = space-before-tab,trailing-space,incomplete-line,tabwidth=4
[diff]
	algorithm = histogram
	indentHeuristic = true
	renameLimit = 2048
	renames = copies
	suppressBlankEmpty = true
[fetch]
	prune = true
	pruneTags = true
[format]
	encodeEmailHeaders = false
	pretty = fuller
	signature = ""
[init]
	defaultBranch = master
[interactive]
	diffFilter = diff-highlight
[mergetool]
	keepBackup = false
[pager]
	branch = false
	diff = diff-highlight | less
	show = diff-highlight | less
[push]
	default = current
	followTags = true
	gpgSign = if-asked
[rebase]
	autoStash = true
	missingCommitsCheck = error
[tag]
	sort = version:refname
